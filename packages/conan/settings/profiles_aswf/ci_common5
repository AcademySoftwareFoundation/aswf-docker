[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=11.2
compiler.libcxx=libstdc++11
compiler.cppstd=17
build_type=Release
[options]
# Build everything as shared libs by default
*:shared=True
[tool_requires]
[replace_requires]
openssl/*: openssl/1.1.1k@aswf/ci_common5
[replace_tool_requires]
cmake/*: cmake/3.31.7@aswf/ci_common5
ninja/*: ninja/1.13.1@aswf/ci_common5
[platform_requires]
[buildenv]
GCC_INSTALL_DIR=/opt/rh/gcc-toolset-11/root/lib/gcc/x86_64-redhat-linux/11
